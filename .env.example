# Open Wallet Standard wallet name or UUID.
# Create one with: python3 helpers/create_ows_wallet.py --name agent-treasury
OWS_WALLET=agent-treasury

# OWS signing chain for vault transactions.
OWS_CHAIN=base

# Optional OWS passphrase or scoped API token.
# Leave unset for an unencrypted local test wallet, or set it in your shell.
# OWS_PASSPHRASE=your_wallet_passphrase_or_ows_key

# Optional custom OWS vault path. Defaults to ~/.ows.
# OWS_VAULT_PATH=/path/to/ows-vault

# Optional path to the full OWS CLI. Required for x402-paid requests.
# OWS_CLI_PATH=/usr/local/bin/ows

# Base RPC URL (optional override)
BASE_RPC_URL=https://mainnet.base.org

# RPC API Key (if using paid RPC provider)
# BASE_RPC_API_KEY=your_key_here

# Vaults.fyi API Key (if required for API access)
VAULTS_API_KEY=your_vaults_api_key_here
