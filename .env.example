VAULTS_API_KEY=

# Opt in to live end-to-end tests. These shell out through the real CLI.
VAULTSFYI_RUN_E2E=0

# Slower sweep over no-funds API commands. Keep off unless intentionally testing live API coverage.
VAULTSFYI_RUN_E2E_FULL=0

# Basic API keys may be limited to 10 requests/minute. The full sweep respects this delay.
VAULTSFYI_E2E_RATE_LIMIT_SECONDS=6.5

# Optional address for portfolio endpoints. Defaults to a valid dummy EVM address when unset.
VAULTSFYI_E2E_USER_ADDRESS=
